VITE_GOOGLE_CLIENT_ID=your_client_key

# Local dev defaults. In Vercel's project env vars (Production), set these to
# your Render backend instead, e.g.:
#   VITE_API_BASE_URL=https://travel-planner-backend.onrender.com/api
#   VITE_WS_BASE_URL=wss://travel-planner-backend.onrender.com/api/chat/ws
VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_WS_BASE_URL=ws://127.0.0.1:8000/api/chat/ws

